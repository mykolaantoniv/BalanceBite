# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with: openssl rand -base64 32

# Google OAuth (get from https://console.developers.google.com/)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Optional: Override Zakaz API endpoints
ZAKAZ_API_BASE=https://stores-api.zakaz.ua
AUCHAN_STORE_ID=48246401

# Optional: Apple OAuth (if implementing Apple sign-in)
APPLE_ID=your_apple_id
APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
